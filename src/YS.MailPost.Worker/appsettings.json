{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "Database": {
    "Provider": "sqlite",
    "ConnectionString": "Data Source=mailpost.db",
    "SqlitePath": "../mailpost.db"
  },
  "Captcha": {
    "Provider": "none"
  },
  "Turnstile": {
    "SecretKey": ""
  },
  "Smtp": {
    "Host": "",
    "Port": "",
    "User": "",
    "Pass": "",
    "UseStartTls": false,
    "UseSsl": true,
    "From": ""
  },
  "FormRouting": {
    "Forms": {
      "ContactForm": {
        "To": "info@yasarsoftware.com",
        "SubjectPrefix": "[Contact]",
        "Template": "Templates/contact.html",
        "RequireCaptcha": false,
        "RateLimitPerMinute": 5,
        "RateLimitPerHour": 30,
        "MinimumSubmissionMilliseconds": 1200,
        "MaxAttempts": 5
      },
      "ContactDetailsForm": {
        "To": "info@yasarsoftware.com",
        "SubjectPrefix": "[Contact Details]",
        "Template": "Templates/contact-details.html",
        "RequireCaptcha": false,
        "RateLimitPerMinute": 5,
        "RateLimitPerHour": 30,
        "MinimumSubmissionMilliseconds": 1200,
        "MaxAttempts": 5
      }
    }
  },
  "Worker": {
    "BatchSize": 25,
    "MaxConcurrency": 4,
    "PollIntervalSeconds": 5,
    "BaseBackoffSeconds": 5,
    "MaxBackoffSeconds": 300,
    "JitterSeconds": 3,
    "MaxAttempts": 5
  }
}
